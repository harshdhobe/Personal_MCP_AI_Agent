# Server
PORT=3000

# Messaging channels (comma-separated): whatsapp, telegram — at least one required
MESSAGING_CHANNELS=telegram

# WhatsApp Cloud API (required when MESSAGING_CHANNELS includes whatsapp)
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_ALLOWED_WA_ID=your_whatsapp_id

# Telegram Bot API (required when MESSAGING_CHANNELS includes telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_CHAT_ID=your_telegram_chat_id
TELEGRAM_WEBHOOK_SECRET=

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
# Prefer flash-lite on free tier (fewer 429s). flash is fallback:
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash

# Speed (optional — recommended for Telegram)
GMAIL_MAX_RESULTS=3
GMAIL_FETCH_CONCURRENCY=8
# Skip 2nd Gemini call for unread/search/summarize (~2-4s faster):
AGENT_FAST_REPLY=1
# Skip extra synthesis when Gemini returns empty (use formatter only):
# AGENT_SKIP_SYNTHESIS=1

# Gmail OAuth 2.0
GMAIL_OAUTH_CLIENT_ID=your_google_client_id
GMAIL_OAUTH_CLIENT_SECRET=your_google_client_secret
GMAIL_OAUTH_REDIRECT_URI=http://127.0.0.1:8844/oauth/callback
GMAIL_REFRESH_TOKEN=your_refresh_token_after_setup

MCP_GMAIL_COMMAND=
# MCP/Gmail tool timeout ms (default 90000; raise on WSL if needed)
MCP_GMAIL_TIMEOUT_MS=90000
# On WSL under /mnt/d/ auto-uses in-process Gmail (no MCP subprocess). Force on Render/Linux:
GMAIL_INPROCESS=1
SESSION_TTL_HOURS=24
